      "RetentionEnabled": true,
      "RetentionDays": 90,
      "RetentionSweepHours": 24,
      "RetentionBatchSize": 200
    }
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "EnableSsl": true,
    "From": "",
    "FromName": "RentalHub",
    "Username": "",
    "Password": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
