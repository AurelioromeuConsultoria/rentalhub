{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=rentalhub;Username=rentalhub;Password=change_me;Timeout=3;Command Timeout=10"
  },
  "Database": {
    "EnsureCreatedOnStartup": true,
    "UseMigrationsOnStartup": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Jwt": {
    "Key": "change-me-with-a-secure-jwt-key-before-production-2026",
    "Issuer": "RentalHub",
    "Audience": "RentalHub",
    "ExpiresMinutes": 120
  },
  "Notifications": {
    "Email": {
      "Enabled": false,
      "DigestHour": 8,
      "IntervalMinutes": 60,
      "HorizonDays": 3,
      "NewReservationHours": 24,
      "TimeZone": "America/Sao_Paulo",
      "SendToOperationalEmail": true,
      "SendToAdmins": true,
      "AdminUrl": ""
    }
  },
  "Privacy": {
